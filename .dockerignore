*.pt
weights/
# local sqlite-vec store
argus.db
# extracted face chips
chips/
.venv
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
__marimo__/
out/
dvr_raw/
dvr_mp4/
examples/
context/
*.md
!README.md
Dockerfile
.dockerignore
Makefile
