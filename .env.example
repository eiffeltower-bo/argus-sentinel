# Copy to .env and adjust — docker compose auto-loads .env for variable substitution.
# .env is gitignored (machine-specific); this .env.example is the committed, documented template.

# Host footage folder, mounted read-only at /data in the dev / mcp containers.
ARGUS_DATA=./data

# torch wheel index used at BUILD time. CPU is the default and works everywhere; for GPU use a
# CUDA index (torch 2.12.0 publishes cu126 and cu130). Changing this requires a rebuild:
#   docker compose build <service>
TORCH_INDEX=https://download.pytorch.org/whl/cpu

# Optional build extras baked into the image. For the full face-ID path use e.g.
# "[face-gpu,store,cluster]" (CPU: "[face,store,cluster]"); add "audio"/"open-vocab" as needed.
EXTRAS=

# MCP server: bind host inside the container, and the port (bound + published on the host).
ARGUS_MCP_HOST=0.0.0.0
ARGUS_MCP_PORT=8000

# Persistent face-sighting DB for the face-ID MCP tools (ingest_clip / list_sightings /
# search_face / search_similar / enroll_identity / cluster_sightings / audit_log). Server-side
# path; the compose default puts it under the bind-mounted ./out so it survives restarts. Populate
# with ingest_clip (or `argus ingest`). ARGUS_EMBED_DIM must match the embedder (512 for ArcFace).
ARGUS_DB=argus.db
ARGUS_EMBED_DIM=512

# OAuth 2.1 for the MCP server (Resource Server role). Default off → no auth (loopback/LAN dev).
# Set ARGUS_MCP_AUTH=on to require a bearer token issued by the IdP below on every request; each
# tool then also needs its scope (argus:peek/track/search/audio/read/ingest/enroll/cluster/audit).
ARGUS_MCP_AUTH=off
# IdP (Authorization Server) base URL — token issuer. Keycloak realm shown (see docker-compose).
ARGUS_OAUTH_ISSUER=http://localhost:8080/realms/argus
# This server's canonical resource URI; tokens MUST be audience-bound to it (RFC 8707).
ARGUS_OAUTH_RESOURCE=http://localhost:8000/mcp
# Optional BLANKET scope(s) the SDK requires on every request (comma/space separated). Blank =
# none (per-tool scopes still apply). Set e.g. "argus:use" to also gate at the transport layer.
ARGUS_OAUTH_SCOPES=
