# Python / uv
.venv/

# local docker compose config (machine-specific paths: ARGUS_DATA, TORCH_INDEX)
.env
__pycache__/
*.pyc
*.pyo

# marimo session cache
__marimo__/

# model weights that auto-download (ultralytics fetches yolo*.pt on first use)
*.pt

# generated artifacts
out/
# downloaded model weights (large; fetched/mounted at runtime)
weights/
# local sqlite-vec store
argus.db
# extracted face chips
chips/

# debugging scratch (HAR captures, client log dumps) under context/
context/*.har
context/claude_logs.json

# pulled DVR footage + transcodes (large, regenerable)
dvr_raw/
dvr_mp4/

# OS
.DS_Store

# Note: models/face_detection_yunet_2023mar.onnx (~232 KB) IS committed —
# it has no auto-download path, and the two-stage notebooks need it.
